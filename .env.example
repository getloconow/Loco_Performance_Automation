# ============================================================
# PERFORMANCE FRAMEWORK - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Execution Environment: "local" | "lambdatest"
# ----------------------------------------------------------
EXECUTION_ENV=local

# ----------------------------------------------------------
# Local Chrome Remote Debugging Port
# ----------------------------------------------------------
CHROME_DEBUG_PORT=9222

# ----------------------------------------------------------
# LambdaTest Credentials (required only when EXECUTION_ENV=lambdatest)
# ----------------------------------------------------------
LT_USERNAME=your_lambdatest_username
LT_ACCESS_KEY=your_lambdatest_access_key

# ----------------------------------------------------------
# LambdaTest Capability Overrides (optional)
# ----------------------------------------------------------
LT_BROWSER_VERSION=latest
LT_PLATFORM=Windows 11
LT_BUILD_NAME=Loco Performance Suite
LT_TUNNEL=false

# ----------------------------------------------------------
# Lighthouse / Test Configuration
# ----------------------------------------------------------
# Number of iterations per test scenario (for averaging vitals)
ITERATION_COUNT=5

# Headless mode for local runs
HEADLESS=false

# ----------------------------------------------------------
# Loco Auth — OTPless Cookie Injection
# ----------------------------------------------------------
# When LOCO_AUTH_ENABLED=true, the suite will:
#   1. Run the OTPless headless SDK to obtain a wa_id token
#   2. Exchange it for access_token + refresh_token via the Loco API
#   3. Inject access_token, refresh_token, mode=logged-in cookies
#      into every browser context before any performance audit runs
# Set to false to run as an anonymous guest (default flow before auth).
LOCO_AUTH_ENABLED=true

# Shared Loco sign-in client credentials (x-client-id / x-client-secret)
# These are the same for both viewer and streamer sign-in calls.
LOCO_AUTH_CLIENT_ID=your_loco_sign_in_client_id
LOCO_AUTH_CLIENT_SECRET=your_loco_sign_in_client_secret

# Viewer App — used by the "loco" viewer project (preprod.loco.com)
LOCO_VIEWER_APP_ID=your_viewer_otpless_app_id
LOCO_VIEWER_PHONE=your_viewer_test_phone_number
LOCO_VIEWER_OTP=your_viewer_static_otp
LOCO_VIEWER_COUNTRY_CODE=+55
LOCO_VIEWER_UID=your_viewer_user_id
LOCO_VIEWER_USERNAME=your_viewer_user_name

# Streamer App — used by the "loco" streamer-dashboard project
LOCO_STREAMER_APP_ID=your_streamer_otpless_app_id
LOCO_STREAMER_PHONE=your_streamer_test_phone_number
LOCO_STREAMER_OTP=your_streamer_static_otp
LOCO_STREAMER_COUNTRY_CODE=+55
