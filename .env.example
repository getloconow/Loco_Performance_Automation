# ============================================================
# PERFORMANCE FRAMEWORK - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Execution Environment: "local" | "lambdatest"
# ----------------------------------------------------------
EXECUTION_ENV=local

# ----------------------------------------------------------
# Local Chrome Remote Debugging Port
# ----------------------------------------------------------
CHROME_DEBUG_PORT=9222

# ----------------------------------------------------------
# LambdaTest Credentials (required only when EXECUTION_ENV=lambdatest)
# ----------------------------------------------------------
LT_USERNAME=your_lambdatest_username
LT_ACCESS_KEY=your_lambdatest_access_key

# ----------------------------------------------------------
# LambdaTest Capability Overrides (optional)
# ----------------------------------------------------------
LT_BROWSER_VERSION=latest
LT_PLATFORM=Windows 11
LT_BUILD_NAME=Loco Performance Suite
LT_TUNNEL=false

# ----------------------------------------------------------
# Lighthouse / Test Configuration
# ----------------------------------------------------------
# Number of iterations per test scenario (for averaging vitals)
ITERATION_COUNT=5

# Headless mode for local runs
HEADLESS=false
